# ========== 数据库 ==========
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_video_marketplace?schema=public"

# ========== Redis ==========
REDIS_URL="redis://localhost:6379"

# ========== JWT ==========
JWT_SECRET="your-jwt-secret-change-in-production"
JWT_EXPIRES_IN="7d"

# ========== 文件存储 (阿里云 OSS) ==========
OSS_REGION="oss-cn-hangzhou"
OSS_ACCESS_KEY_ID="your-access-key"
OSS_ACCESS_KEY_SECRET="your-access-key-secret"
OSS_BUCKET="ai-video-marketplace"
OSS_ENDPOINT="https://oss-cn-hangzhou.aliyuncs.com"

# ========== 支付 (微信支付) ==========
WECHAT_APP_ID="your-app-id"
WECHAT_MCH_ID="your-merchant-id"
WECHAT_API_KEY="your-api-key"
WECHAT_NOTIFY_URL="https://your-domain.com/api/pay/wechat/notify"

# ========== 支付 (支付宝) ==========
ALIPAY_APP_ID="your-app-id"
ALIPAY_PRIVATE_KEY="your-private-key"
ALIPAY_PUBLIC_KEY="your-public-key"
ALIPAY_NOTIFY_URL="https://your-domain.com/api/pay/alipay/notify"

# ========== AI 服务 ==========
KLING_API_KEY="your-kling-api-key"
FLUX_API_KEY="your-flux-api-key"

# ========== 短信验证码 (阿里云) ==========
SMS_ACCESS_KEY_ID="your-sms-access-key"
SMS_ACCESS_KEY_SECRET="your-sms-access-key-secret"
SMS_SIGN_NAME="AI视频平台"
SMS_TEMPLATE_CODE="SMS_123456789"

# ========== 应用配置 ==========
APP_PORT=3001
FRONTEND_URL="http://localhost:3000"
